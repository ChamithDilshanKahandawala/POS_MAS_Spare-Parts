{
  "name": "mas-print-agent",
  "version": "1.0.0",
  "description": "Local print agent for Mudiyanse Auto Solutions POS — sends ESC/POS commands to XP-Q80B via Windows shared printer",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "install-service": "node install-service.js",
    "uninstall-service": "node uninstall-service.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-thermal-printer": "^4.4.1",
    "node-windows": "^1.0.0-beta.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "MAS Dev",
  "license": "MIT"
}
