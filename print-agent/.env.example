# ── Print Agent ──────────────────────────────────────────────
# Port the agent listens on
AGENT_PORT=9100

# Local Windows printer name — exactly as it appears in "Devices and Printers"
# Run in PowerShell to find it: Get-Printer | Select-Object Name
WINDOWS_PRINTER_NAME=POS-80C

# Cash drawer kick (true/false) — kicks ONLY on Cash payment
DRAWER_ENABLED=true

# CORS — comma-separated origins allowed to call this agent
ALLOWED_ORIGINS=http://localhost:5173,https://pos-mas-spare-parts.vercel.app
